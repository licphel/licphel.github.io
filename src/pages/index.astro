---
import Layout from '../layouts/Layout.astro';
import { Content, frontmatter as home } from '../data/home.md';
---

<Layout title="Home" description={`${home.profileName} — personal homepage`}>
  <div class="max-w-2xl">
    <!-- Profile -->
    <div class="flex items-start gap-6 mb-10">
      <img src="/avatar.jpg" alt={home.profileName} class="w-24 h-24 rounded-full avatar-glow object-cover flex-shrink-0" />
      <div>
        <h2 class="text-3xl font-bold text-gray-900 mb-1 font-serif">{home.profileName}</h2>
        <p class="text-sm mb-2 text-gray-400">{home.profileSubtitle}</p>
        {home.profileLines.map((line: string) => (
          <p class="text-xs text-gray-400 tracking-wide">{line}</p>
        ))}
      </div>
    </div>

    <!-- Markdown body -->
    <article class="home-content">
      <Content />
    </article>
  </div>
</Layout>

<style>
  .home-content {
    font-family: var(--font-serif);
    font-size: 1.075rem;
    line-height: 1.2;
    color: #2d2d3a;
  }
  .home-content h2 {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 600;
    margin: 1.6rem 0 0.5rem;
    color: #111;
  }
  .home-content p {
    margin-bottom: 1rem;
    color: #2d2d3a;
  }
  .home-content ul {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }
  .home-content li {
    margin-bottom: 0.3rem;
  }
</style>
