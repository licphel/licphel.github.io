---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="Licphel — personal homepage">
  <div class="max-w-2xl">
    <!-- Profile -->
    <div class="flex items-start gap-6 mb-10">
      <img src="/avatar.jpg" alt="Licphel" class="w-24 h-24 rounded-full avatar-glow object-cover flex-shrink-0" />
      <div>
        <h2 class="text-3xl font-bold text-gray-900 mb-1 font-serif">Licphel</h2>
        <p class="text-sm mb-2 text-gray-400">アルカディア狐</p>
        <p class="text-xs text-gray-400 tracking-wide">
          CS Student · Algorithms · Machine Learning · Systems
        </p>
      </div>
    </div>

    <!-- About -->
    <section class="content-card mb-6">
      <h3 class="text-lg font-semibold mb-3 text-gray-900">About Me</h3>
      <p class="text-gray-600 leading-relaxed">
        Hi! I'm Licphel. I'm passionate about algorithms, machine learning, and building
        systems. This site is where I share my notes, papers, and projects. Currently
        exploring the intersections of theoretical computer science and deep learning.
      </p>
    </section>

    <!-- Interests -->
    <section class="content-card mb-6">
      <h3 class="text-lg font-semibold mb-4 text-gray-900">Interests</h3>
      <div class="flex flex-wrap gap-2">
        {
          ['Algorithms', 'Data Structures', 'Machine Learning', 'Deep Learning',
           'Graph Theory', 'Optimization', 'Computer Vision', 'NLP',
           'Reinforcement Learning', 'Distributed Systems', 'Rust', 'Python'
          ].map(tag => (
            <span class="tag">{tag}</span>
          ))
        }
      </div>
    </section>

    <!-- Links -->
    <section class="content-card">
      <h3 class="text-lg font-semibold mb-4 text-gray-900">Links</h3>
      <div class="flex flex-wrap gap-4">
        <a href="https://github.com/licphel" target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-2 text-sm px-4 py-2 rounded-lg border border-gray-200 text-gray-700 hover:border-purple-300 hover:text-purple-700 transition-colors no-underline">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          GitHub
        </a>
        <a href="/blogs"
           class="inline-flex items-center gap-2 text-sm px-4 py-2 rounded-lg border border-gray-200 text-gray-700 hover:border-purple-300 hover:text-purple-700 transition-colors no-underline">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          Blog
        </a>
        <a href="/papers"
           class="inline-flex items-center gap-2 text-sm px-4 py-2 rounded-lg border border-gray-200 text-gray-700 hover:border-purple-300 hover:text-purple-700 transition-colors no-underline">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Papers
        </a>
      </div>
    </section>
  </div>
</Layout>
